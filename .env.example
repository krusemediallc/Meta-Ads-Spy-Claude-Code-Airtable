# Meta Ad Library access token.
# Get one from https://developers.facebook.com/tools/explorer/ (or any Meta developer app).
# Only needs "public_profile" permission — the Ad Library endpoint is public.
META_ACCESS_TOKEN=

# Airtable Personal Access Token.
# Create one at https://airtable.com/create/tokens
# Required scopes: data.records:write, schema.bases:read
# Grant access to the base you copied in Step 1.
AIRTABLE_PAT=
